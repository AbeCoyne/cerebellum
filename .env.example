SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

OPENROUTER_API_KEY=your-openrouter-api-key-here
EMBEDDING_MODEL=openai/text-embedding-3-small
CLASSIFIER_MODEL=openai/gpt-4o-mini

# HTTP Daemon
CEREBELLUM_API_KEY=    # Required for HTTP server — generate with: openssl rand -hex 32
CEREBELLUM_PORT=4891   # Optional, default 4891

# Seed pipeline — controls how `memo seed` routes entries
# 'gk'     — skip Operator, land in GK queue for `memo review` (default, recommended for curated batches)
# 'direct' — straight to DB, no quality gate (fastest, for pre-vetted batches)
# 'full'   — through Operator + GK queue (for raw/uncertain batches)
SEED_PIPELINE=gk
